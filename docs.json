{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Trusset Protocol",
  "description": "End-to-end infrastructure for tokenizing any asset",
  "colors": {
    "primary": "#FD4319",
    "light": "#FD4319",
    "dark": "#FD4319"
  },
  "favicon": "/favicon.png",
  "fonts": {
    "body": {
      "family": "Questrial",
      "weight": 400
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "api": {
    "mdx": {
      "server": "https://api.trusset.org",
      "auth": {
        "method": "key",
        "name": "x-api-key"
      }
    }
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "description": "Trusset Protocol provides end-to-end infrastructure for tokenizing any asset. Build on our blockchain platform for asset tokenization, DeFi trading, and collateralized lending.",
      "keywords": "asset tokenization, blockchain infrastructure, DeFi platform, tokenized assets, smart contracts, collateralized loans, asset financing, multi-chain bridge, real-world assets, RWA tokenization",
      "author": "Trusset Protocol",
      "robots": "index, follow",
      "googlebot": "index, follow",
      "language": "en",
      "category": "Blockchain Technology",
      "distribution": "global",
      "coverage": "Worldwide",
      "target": "developers, institutions, asset managers",
      "theme-color": "#FD4319",
      "og:title": "Trusset Protocol - Infrastructure for Asset Tokenization",
      "og:type": "website",
      "og:url": "https://docs.trusset.org",
      "og:image": "https://docs.trusset.org/assets/logo.png",
      "og:description": "End-to-end infrastructure for tokenizing any asset. Build DeFi applications, manage tokenized assets, and access collateralized lending on our blockchain platform.",
      "og:site_name": "Trusset Protocol Documentation",
      "og:locale": "en_US",
      "article:section": "Blockchain Technology",
      "article:tag": "blockchain, tokenization, DeFi, smart contracts, asset management, collateral, lending, trading",
      "application-name": "Trusset Protocol Docs",
      "HandheldFriendly": "True",
      "MobileOptimized": "320",
      "viewport": "width=device-width, initial-scale=1.0",
      "charset": "UTF-8"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Protocol",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "protocol/intro",
              {
                "group": "Core Infrastructure",
                "pages": [
                  "protocol/infrastructure/core-infrastructure",
                  "protocol/infrastructure/instances",
                  "protocol/infrastructure/data-storage",
                  "protocol/infrastructure/relayer",
                  "protocol/infrastructure/custody",
                  "protocol/infrastructure/networks"
                ]
              },
              {
                "group": "Integration",
                "pages": [
                  "protocol/integration/overview"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "API-Keys",
            "pages": [
              "api-key-management"
            ]
          },
          {
            "group": "Gold",
            "pages": [
              "new/guides/gold/creation",
              "new/guides/gold/trading",
              "soon-more"
            ]
          },
          {
            "group": "Stocks",
            "pages": [
              "new/guides/stocks/creation",
              "new/guides/stocks/trading",
              "new/guides/stocks/lending"
            ]
          }
        ]
      },
      {
        "tab": "Licenses",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "licenses/introduction",
              "licenses/audits"
            ]
          },
          {
            "group": "Commodity Token License",
            "pages": [
              "licenses/commodities/introduction",
              "licenses/commodities/contracts",
              "licenses/commodities/integration",
              "licenses/commodities/best-practices"

            ]
          },
          {
            "group": "Stock Token License",
            "pages": [
              "licenses/stocks/introduction",
              "licenses/stocks/contracts",
              "licenses/stocks/integration",
              "licenses/stocks/best-practices"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Trusset",
          "href": "https://trusset.org",
          "icon": "globe"
        },
        {
          "anchor": "MiCA Register",
          "href": "https://trusset.org/mica-register",
          "icon": "building"
        },
        {
          "anchor": "Demo Call",
          "href": "https://cal.com/paul-ilami-trusset",
          "icon": "phone"
        }
      ]
    }
  },
  "errors": {
    "404": {
      "redirect": true,
      "title": "I can't be found",
      "description": "What ever **happened** to this _page_?"
    }
  },
  "logo": {
    "light": "/logo/patchOrange.png",
    "dark": "/logo/patchOrange.png"
  },
  "navbar": {
